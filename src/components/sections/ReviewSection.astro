---
import * as enTranslations from "../../content/i18n/en";
import * as esTranslations from "../../content/i18n/es";

interface Review {
  author: string;
  text: string;
  image: string;
  rating: number;
  imagePosition?: string;
}

interface ReviewsSection {
  title: string;
  photoAltPrefix: string;
  items: Review[];
}

const { currentLocale } = Astro;
const locale = currentLocale || "en";

// Get translations based on locale
const translations =
  locale === "en" ? enTranslations.default : esTranslations.default;
const { reviews } = translations;

// Get the base URL based on locale
const baseUrl = locale === "en" ? "" : "/es";
---

<style>
  .review-section {
    position: relative;
    overflow: hidden;
    padding: 2rem 1rem;
  }

  .review-slider {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 100%;
    gap: 1rem;
    overflow-x: auto;
    scroll-behavior: smooth;
    overscroll-behavior-inline: contain;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE y Edge */
  }

  .review-slider::-webkit-scrollbar {
    display: none; /* Chrome, Safari y Opera */
  }

  .review {
    border-radius: 1rem;
    padding: 2rem 1.5rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .review-author {
    margin-top: 1rem;
    font-weight: bold;
    color: #e5e5db;
    margin-bottom: 0.5rem;
    margin-top: 0rem;
    font-size: 1.3rem;
  }

  .controls {
    display: flex;
    justify-content: space-around;
    gap: 1rem;
    margin-top: 1rem;
  }

  button {
    background: #000;
    color: white;
    border: none;
    border-radius: 50%;
    width: 2.5rem;
    height: 2.5rem;
    cursor: pointer;
    transition: background 0.3s;
  }

  button:hover {
    background: #262626;
  }

  .review-image {
    width: 8rem;
    height: 8rem;
    border-radius: 9999px;
    object-fit: cover;
    margin: 0;
    margin-bottom: 0rem;
  }
  .p {
    font-size: 1.05rem;
    font-weight: 400;
    line-height: 1.6;
    margin: 0.5rem 0 1rem 0;
  }
  .stars {
    display: flex;
    gap: 0.2rem;
    font-size: 1rem;
    margin: 0rem 0;
    margin-top: 0rem;
  }
  .star {
    color: #555;
    font-size: 1.4rem;
  }

  .star.filled {
    color: #e1ba8e;
  }

  @media (min-width: 640px) {
    .review-slider {
      grid-auto-columns: 50%;
    }
  }

  @media (min-width: 1024px) {
    .review-slider {
      grid-auto-columns: 25%;
    }
  }
</style>

<section id="reviews" class="review-section">
  <h2
    class="mb-8 text-center text-3xl font-bold text-neutral-800 dark:text-neutral-200"
  >
    {reviews.title}
  </h2>
  <div class="review-slider" id="reviewSlider">
    {
      reviews.items.map((review: Review) => (
        <div class="review bg-neutral-100 dark:bg-white/[.075]">
          <img
            src={review.image}
            alt={`${reviews.photoAltPrefix} ${review.author}`}
            class="review-image"
            style={
              review.imagePosition
                ? `object-position: ${review.imagePosition};`
                : undefined
            }
          />
          <div class="stars">
            {Array.from({ length: 6 }).map((_, i) => (
              <span class={i < review.rating ? "star filled" : "star"}>★</span>
            ))}
          </div>
          <div class="review-author text-neutral-900 dark:text-neutral-200">
            — {review.author}
          </div>
          <p class="p text-neutral-600 dark:text-neutral-300">
            — {review.text}
          </p>
        </div>
      ))
    }
  </div>

  <div class="controls">
    <button type="button" onclick="prevSlide()">‹</button>
    <button type="button" onclick="nextSlide()">›</button>
  </div>

  <script is:inline>
    let currentIndex = 0;
    const slider = document.getElementById("reviewSlider");

    function getSlidesPerView() {
      return window.innerWidth >= 1024 ? 4 : window.innerWidth >= 640 ? 2 : 1;
    }

    function updateSlider() {
      const slide = slider.children[0];
      if (!slide) return;

      const slideWidth = slide.offsetWidth;
      const slidesPerView = getSlidesPerView();
      const maxIndex = slider.children.length - slidesPerView;

      // Mantener currentIndex dentro del rango válido
      currentIndex = Math.max(0, Math.min(currentIndex, maxIndex));

      // Scroll al índice deseado
      slider.scrollTo({
        left: slideWidth * currentIndex,
        behavior: "smooth",
      });
    }

    function nextSlide() {
      const slidesPerView = getSlidesPerView();
      const maxIndex = slider.children.length - slidesPerView;
      currentIndex = currentIndex < maxIndex ? currentIndex + 1 : 0;
      updateSlider();
    }

    function prevSlide() {
      const slidesPerView = getSlidesPerView();
      const maxIndex = slider.children.length - slidesPerView;
      currentIndex = currentIndex > 0 ? currentIndex - 1 : maxIndex;
      updateSlider();
    }

    window.addEventListener("resize", updateSlider);
    setInterval(nextSlide, 8000);
    updateSlider();
  </script>
</section>
