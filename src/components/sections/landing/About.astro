---
import FeaturesNavs from "../features/FeaturesNavs.astro";
import AbountOne from "@images/about/about_1.webp";
import AbountTwo from "@images/about/about_2.webp";
import AbountThree from "@images/about/about_3.webp";

// Traducción dinámica
const { t } = Astro.props;

// Imágenes (puedes también cargarlas dinámicamente si quieres, pero así es más simple)
const images = [AbountOne, AbountTwo, AbountThree];
---
<section id="about" class="my-20">
  <FeaturesNavs
    title={t.about?.title || "About Us"}
    subTitle={t.about?.subTitle || `Welcome to our <span class="text-yellow-500 dark:text-yellow-400">family</span> in the world of dreams come true!`}
    tabs={[
      {
        ...t.about?.tabs?.[0],
        svg: "tools",
        src: AbountOne,
        alt: t.about?.tabs?.[0]?.alt || "Yellow and black heavy equipment on brown grass field",
        first: true,
      },
      {
        ...t.about?.tabs?.[1],
        svg: "dashboard",
        src: AbountTwo,
        alt: t.about?.tabs?.[1]?.alt || "A screenshot or graphic representation of the intuitive dashboard",
      },
      {
        ...t.about?.tabs?.[2],
        svg: "house",
        src: AbountThree,
        alt: t.about?.tabs?.[2]?.alt || "Gray metal building frame near tower crane during daytime",
      },
    ]}
  />
</section>