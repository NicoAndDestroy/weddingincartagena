---
const { t } = Astro.props;
---

<section
  id="contact-form"
  class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14"
>
  <!-- Header -->
  <div class="mx-auto max-w-3xl text-center">
    <h2 class="text-3xl font-bold dark:text-white sm:text-4xl">
      {t.form.title}
    </h2>
    <p class="mt-3 text-neutral-600 dark:text-neutral-400">
      {t.form.subtitle}
    </p>
  </div>

  <!-- Form -->
  <div class="mx-auto mt-12 max-w-2xl">
    <form id="wedding-lead-form" class="grid gap-5 form-card">
      <!-- Name -->
      <input
        type="text"
        name="name"
        placeholder={t.form.name}
        required
      />

      <!-- Email -->
      <input
        type="email"
        name="email"
        placeholder={t.form.email}
        required
      />

      <!-- Phone -->
      <input
        type="tel"
        name="phone"
        placeholder={t.form.phone}
      />

      <!-- Wedding date -->
      <input
        type="date"
        name="date"
      />

      <!-- Guests -->
      <input
        type="number"
        name="guests"
        placeholder={t.form.guests}
      />

      <!-- Message -->
      <textarea
        name="message"
        rows="4"
        placeholder={t.form.message}
      ></textarea>

      <button type="submit" class="w-full submit-btn">
        {t.form.cta}
      </button>

      <!-- Success -->
      <p id="form-success" class="hidden success-message">
        {t.form.success}
      </p>
    </form>
  </div>
</section>

<!-- PRO SUBMIT -->
<script is:inline>
  const form = document.getElementById("wedding-lead-form");
  const success = document.getElementById("form-success");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const button = form.querySelector("button");
    const originalText = button.innerText;

    button.disabled = true;
    button.innerText = "Sending...";

    const data = new FormData(form);

    try {
      await fetch("https://formspree.io/f/XXXXXXX", {
        method: "POST",
        body: data,
        headers: { Accept: "application/json" },
      });

      success.classList.remove("hidden");

      setTimeout(() => {
        window.location.href =
          "https://wa.me/573004128389?text=Hi! I just submitted the wedding form.";
      }, 2500);

    } catch (err) {
      button.disabled = false;
      button.innerText = originalText;
    }
  });
</script>

<style>
/* ==================================================
   Lead Form – Le Mariage Identity
================================================== */

/* container rhythm */
#contact-form {
  position: relative;
}

/* =============================
   Card
============================= */

.form-card {
  position: relative;
  padding: clamp(2rem, 3vw, 3rem);
  border-radius: 22px;

  background:
    radial-gradient(circle at top left, rgba(255,184,107,.08), transparent 40%),
    rgba(255,255,255,.03);

  border: 1px solid rgba(255,255,255,.08);

  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);

  box-shadow:
    0 20px 80px rgba(0,0,0,.35);
}

/* champagne edge glow */
.form-card::after {
  content: "";
  position: absolute;
  inset: -1px;
  border-radius: inherit;
  padding: 1px;
  background: linear-gradient(120deg, transparent, rgba(255,184,107,.5), transparent);
  -webkit-mask:
    linear-gradient(#000 0 0) content-box,
    linear-gradient(#000 0 0);
  -webkit-mask-composite: xor;
          mask-composite: exclude;
  pointer-events: none;
  opacity: .5;
}

/* =============================
   Inputs
============================= */

#contact-form input,
#contact-form textarea {
  width: 100%;
  padding: 1.1rem 1.2rem;
  border-radius: 16px;

  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.07);
  color: #fff;

  font-size: 1rem;

  transition: all .25s ease;
}

/* placeholders */
#contact-form input::placeholder,
#contact-form textarea::placeholder {
  color: rgba(255,255,255,.55);
}

/* focus */
#contact-form input:focus,
#contact-form textarea:focus {
  outline: none;
  border-color: var(--sl-color-accent);
  box-shadow: 0 0 0 4px rgba(255,184,107,.15);
  transform: translateY(-1px);
}

/* textarea */
#contact-form textarea {
  resize: vertical;
  min-height: 140px;
}

/* =============================
   CTA
============================= */

.submit-btn {
  margin-top: 1rem;

  background: linear-gradient(
    135deg,
    #f5c58b,
    #e3a85d
  );

  color: #2a2a2a;
  font-weight: 700;

  padding: 1.1rem;
  border-radius: 16px;

  transition: all .25s ease;
}

/* hover */
.submit-btn:hover {
  transform: translateY(-3px);
  box-shadow: 0 15px 40px rgba(0,0,0,.3);
}

/* disabled */
.submit-btn:disabled {
  opacity: .7;
  cursor: not-allowed;
  transform: none;
}

/* =============================
   Success
============================= */

.success-message {
  margin-top: 1.2rem;
  text-align: center;
  color: #f5c58b;
  font-weight: 600;
  animation: fadeInUp .4s ease;
}

/* =============================
   Animation
============================= */

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* =============================
   Mobile
============================= */

@media (max-width: 640px) {
  .form-card {
    padding: 1.7rem;
    border-radius: 18px;
  }
}

</style>
