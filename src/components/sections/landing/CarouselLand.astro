---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

/**
 * Load all landscape images dynamically.
 * Safe even if files are deleted.
 */
const imagesLand = import.meta.glob<{ default: ImageMetadata }>(
  "/src/images/values/land/*.jpg",
  { eager: true },
);

/**
 * Normalize images
 */
const imageArrayLand = Object.values(imagesLand).map((img) => ({
  src: img.default,
  mode: "land",
}));

const alt = "Wedding in Cartagena Colombia - Le Mariage";
const title = "Wedding in Cartagena Colombia - Le Mariage";
const hasImages = imageArrayLand.length > 0;
---

<!-- =======================
 Wedding Land Carousel
======================= -->
<section id="wedding-slider-land" class="relative" aria-label={title}>
  <div class="swiper">
    <div class="swiper-wrapper">
      {
        hasImages ? (
          imageArrayLand.map((image) => (
            <div class="swiper-slide">
              <Image
                src={image.src}
                alt={alt}
                class="aspect-[5/3] w-full object-cover"
                loading="lazy"
              />
            </div>
          ))
        ) : (
          <div class="swiper-slide">
            <div class="flex aspect-[5/3] w-full items-center justify-center bg-gray-200 text-sm text-gray-600">
              No images available
            </div>
          </div>
        )
      }
    </div>

    <!-- Pagination -->
    <div class="swiper-pagination"></div>

    <!-- Navigation -->
    <button
      type="button"
      class="swiper-button-prev"
      aria-label="Previous slide"
      aria-controls="wedding-slider-land"></button>

    <button
      type="button"
      class="swiper-button-next"
      aria-label="Next slide"
      aria-controls="wedding-slider-land"></button>
  </div>
</section>

<!-- =======================
 Swiper Init
======================= -->
<script>
  import Swiper from "swiper";
  import { Navigation, Pagination, Autoplay } from "swiper/modules";

  import "swiper/css";
  import "swiper/css/navigation";
  import "swiper/css/pagination";
  import "swiper/css/autoplay";

  const container = document.querySelector("#wedding-slider-land .swiper");

  if (container instanceof HTMLElement) {
    const slidesCount = container.querySelectorAll(".swiper-slide").length;

    if (slidesCount > 0) {
      new Swiper(container, {
        modules: [Navigation, Pagination, Autoplay],
        slidesPerView: 1,
        spaceBetween: 40,
        loop: slidesCount > 1,
        autoplay:
          slidesCount > 1
            ? { delay: 5000, disableOnInteraction: false }
            : false,
        pagination: {
          el: ".swiper-pagination",
          clickable: true,
        },
        navigation: {
          prevEl: ".swiper-button-prev",
          nextEl: ".swiper-button-next",
        },
      });
    }
  }
</script>
