---
import { Image } from "astro:assets";

/**
 * Load all landscape images dynamically.
 * Using folder-based glob to avoid build errors when files are deleted.
 */
const imagesLand = import.meta.glob(
  '/src/images/values/land/*.jpg',
  { eager: true }
);

// Normalize images array
// @ts-ignore
const imageArrayLand = Object.values(imagesLand).map((image) => ({
  ...image,
  mode: 'land',
}));

const alt = "Wedding in Cartagena Colombia - Le Mariage";
const title = "Wedding in Cartagena Colombia - Le Mariage";
const hasImages = imageArrayLand.length > 0;
---

<!-- =======================
 Wedding Land Carousel
======================= -->
<section
  id="wedding-slider-land"
  class="relative"
  aria-label={title}
>
  <!-- Slider main container -->
  <div class="swiper">
    <!-- Additional required wrapper -->
    <div class="swiper-wrapper">

      {hasImages ? (
        imageArrayLand.map((image) => (
          <div class="swiper-slide">
            <Image
              class="w-full aspect-[5/3] object-cover"
              src={image.default}
              alt={alt}
              loading="lazy"
            />
          </div>
        ))
      ) : (
        <!-- Fallback slide -->
        <div class="swiper-slide">
          <div class="w-full aspect-[5/3] flex items-center justify-center bg-gray-200 text-gray-600 text-sm">
            No images available
          </div>
        </div>
      )}

    </div>

    <!-- Pagination -->
    <div class="swiper-pagination"></div>

    <!-- Navigation -->
    <div class="swiper-button-prev" aria-label="Previous slide"></div>
    <div class="swiper-button-next" aria-label="Next slide"></div>
  </div>
</section>

<!-- =======================
 Swiper Init
======================= -->
<script>
  import Swiper from 'swiper';
  import { Navigation, Pagination, Autoplay } from 'swiper/modules';

  import 'swiper/css';
  import 'swiper/css/navigation';
  import 'swiper/css/pagination';
  import 'swiper/css/autoplay';

  const container = document.querySelector('#wedding-slider-land .swiper');
  const slidesCount = document.querySelectorAll(
    '#wedding-slider-land .swiper-slide'
  ).length;

  if (container && slidesCount > 0) {
    new Swiper(container, {
      modules: [Navigation, Pagination, Autoplay],
      slidesPerView: 1,
      spaceBetween: 40,
      loop: slidesCount > 1,
      autoplay: slidesCount > 1
        ? { delay: 5000, disableOnInteraction: false }
        : false,
      pagination: {
        el: '.swiper-pagination',
        clickable: true,
      },
      navigation: {
        prevEl: '.swiper-button-prev',
        nextEl: '.swiper-button-next',
      },
    });
  }
</script>
