---
// Import the necessary dependencies
import WhatsappBtn from "@components/ui/buttons/WhatsappBtn.astro";

// Define props from Astro
const {
  title,
  subTitle,
  primaryBtn,
  primaryBtnURL,
} = Astro.props;

// Define TypeScript interface for props
interface Props {
  title: string;
  subTitle?: string;
  primaryBtn?: string;
  primaryBtnURL?: string;
  secondaryBtnURL?: string;
  withReview?: boolean;
  avatars?: string[];
  rating?: string;
  starCount?: number;
  reviews?: string;
  src?: any;
  alt?: string;
}
---

<!-- Defining a grid container that holds all the content -->
<section
  id="hero"
  class="mx-auto px-4 py-14 my-20 sm:px-6 lg:px-8 flex flex-col md:flex-row max-w-[85rem] gap-16 md:items-center md:gap-8 2xl:max-w-full"
>
  <!-- Title and description -->
  <div class="w-full">
    <!-- Each h1 and p tag renders a portion of the title and subTitle defined above -->
    <h1
      class="block text-balance text-5xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 sm:text-4xl lg:text-6xl lg:leading-tight"
    >
      <!-- About Fragment: https://docs.astro.build/en/basics/astro-syntax/#fragments -->
      <Fragment set:html={title} />
    </h1>
    {subTitle &&
    <p
      class="mt-3 text-pretty text-[18px] leading-relaxed text-neutral-700 dark:text-neutral-400 lg:w-4/5"
    >
      <Fragment set:html={subTitle} />
    </p>
  }
    <!-- Action Button Section: This section includes two CTAs with their own styles and URL -->
    <div class="mt-7 grid w-full gap-3 sm:inline-flex">
      {primaryBtn && 
      <WhatsappBtn title={primaryBtn} url={primaryBtnURL} />
      }
    </div>
  </div>
<!-- Hero Image Section -->
<div class="flex w-full">
  <div class="top-12 overflow-hidden">
    <!-- Video para pantallas grandes -->
    <video 
      src="/videos/Video Le Mariage.mp4" 
      class="hidden lg:block rounded-xl" 
      autoplay 
      muted 
      loop 
      playsinline 
      controls
    ></video>

    <!-- Video para pantallas pequeñas -->
    <video 
      src="/videos/Hero-Web-Mobile - (9x16).mp4" 
      class="block lg:hidden rounded-xl" 
      autoplay 
      muted 
      loop 
      playsinline 
      controls
    ></video>
  </div>
</div>
</section>
