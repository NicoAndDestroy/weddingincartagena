---
// Import the necessary dependencies
import FooterSocialLink from "@components/ui/links/FooterSocialLink.astro";
import BrandLogo from "@components/BrandLogo.astro";

// Get translation prop if passed
const { t } = Astro.props;

const footerSections = t?.footer?.links || t?.footerLinks || [
  {
    section: "Navigation",
    links: [
      { name: "Home", url: "/" },
      { name: "Español", url: "/es/" },
      { name: "About", url: "/about/" },
      { name: "Contact", url: "/contact/" },
    ],
  },
];

const isExternalUrl = (url: string) => {
  return url.startsWith("http://") || url.startsWith("https://");
};
---

<footer class="w-full bg-neutral-300 dark:bg-neutral-900">
  <div
    class="mx-auto w-full max-w-[85rem] px-4 py-10 sm:px-6 lg:px-16 lg:pt-20 2xl:max-w-screen-2xl"
  >
    <div class="grid grid-cols-1 gap-6 md:grid-cols-3 lg:grid-cols-4">
      <div class="col-span-full lg:col-span-1">
        <a href="/" aria-label="Wedding in Cartagena homepage">
          <BrandLogo class="h-auto w-52" />
        </a>
      </div>

      <nav class="contents" aria-label="Footer navigation">
        {
          footerSections.map((section: any) => (
            <div class="footer-section">
              <h4 class="mb-2 text-lg font-semibold text-neutral-800 dark:text-neutral-100">
                {section.section}
              </h4>

              <ul class="space-y-1">
                {
                  section.links.map((link: any) => {
                    const external = isExternalUrl(link.url);

                    return (
                      <li>
                        <a
                          href={link.url}
                          target={external ? "_blank" : undefined}
                          rel={external ? "noopener noreferrer" : undefined}
                          class="text-neutral-600 transition-colors duration-200 hover:text-yellow-500 dark:text-neutral-400 dark:hover:text-yellow-400"
                        >
                          {link.name}
                        </a>
                      </li>
                    );
                  })
                }
              </ul>
            </div>
          ))
        }
      </nav>
    </div>

    <div
      class="mt-9 grid gap-y-4 border-t border-neutral-400/30 pt-6 sm:mt-12 lg:grid-cols-3 lg:items-center"
    >
      {/* Copyright */}
      <div class="text-center lg:text-left">
        <p class="text-sm text-neutral-600 dark:text-neutral-400">
          {t?.footer?.copyright || "© "}
          <span id="current-year"></span>
          {" "}
          {t?.footer?.brand || "Wedding in Cartagena by Le Mariage. All rights reserved."}
        </p>
      </div>

      {/* Developer Credit */}
      <div class="text-center">
        <p class="text-xs text-neutral-500 dark:text-neutral-500">
          Website crafted by{" "}
          <a
            href="https://nick-portfolio-iota.vercel.app/"
            target="_blank"
            rel="noopener noreferrer"
            class="font-medium underline decoration-neutral-400 underline-offset-4 transition-colors duration-200 hover:text-yellow-500 hover:decoration-yellow-500 dark:decoration-neutral-600 dark:hover:text-yellow-400 dark:hover:decoration-yellow-400"
            aria-label="Visit Nick.dev portfolio"
          >
            Nick.dev
          </a>
        </p>
      </div>

      {/* Social Brands */}
      <div
        class="flex items-center justify-center gap-3 lg:justify-end"
        aria-label="Social media links"
      >
        <FooterSocialLink url="https://facebook.com/lemariagecartagena">
          <img
            class="w-[26px]"
            src="/icons/facebook.svg"
            alt="Facebook Le Mariage"
          />
        </FooterSocialLink>

        <FooterSocialLink url="https://www.instagram.com/lemariagectg_weddingplanner/">
          <img
            class="w-[26px]"
            src="/icons/instagram.svg"
            alt="Instagram Le Mariage"
          />
        </FooterSocialLink>

        <FooterSocialLink url="https://www.tiktok.com/@le.mariage.ctg">
          <img
            class="w-[26px]"
            src="/icons/tiktok.svg"
            alt="TikTok Le Mariage"
          />
        </FooterSocialLink>
      </div>
    </div>

    <script>
      const year = new Date().getFullYear();
      const element = document.getElementById("current-year");

      if (element) {
        element.innerText = year.toString();
      }
    </script>
  </div>
</footer>