---
import { getImage } from "astro:assets";
import { OG, SEO, SITE } from "@data/constants";
import faviconSvgSrc from "@images/icon.svg";
import faviconSrc from "@images/icon.png";

// ================================
// Default Meta Props
// ================================
const defaultProps = {
  meta: SITE.description,
  structuredData: SEO.structuredData,
};

const {
  meta = defaultProps.meta,
  structuredData = defaultProps.structuredData,
} = Astro.props;

// ================================
// URL & Page Context
// ================================
const SITE_URL = `${Astro.site}`.replace(/\/$/, "");
const canonical = Astro.url.href;
const pathname = Astro.url.pathname;

// Detect language from URL
const isEnglish = pathname.startsWith("/en");
const lang = isEnglish ? "en" : "es";
const ogLocale = isEnglish ? "en_US" : "es_CO";

// ================================
// SEO Core
// ================================
const author = SITE.author;
const ogTitle = OG.title;
const ogDescription = OG.description;

// ================================
// Open Graph Image
// ================================
const socialImageRes = await getImage({
  src: OG.image,
  width: 1200,
  height: 630,
});
const socialImage = Astro.url.origin + socialImageRes.src;

// ================================
// Hreflang
// ================================
const languages: { [key: string]: string } = {
  es: "es",
  en: "en",
};

function createHref(prefix: string) {
  if (prefix === "es") {
    return `${SITE_URL}${pathname.replace(/^\/en/, "")}`;
  }
  return `${SITE_URL}/en${pathname.replace(/^\/en/, "")}`;
}

const alternateLanguageLinks = Object.entries(languages)
  .map(
    ([lang, prefix]) =>
      `<link rel="alternate" hreflang="${lang}" href="${createHref(prefix)}" />`
  )
  .join("\n");

// ================================
// Favicons
// ================================
const faviconSvg = await getImage({
  src: faviconSvgSrc,
  format: "svg",
});

const appleTouchIcon = await getImage({
  src: faviconSrc,
  width: 180,
  height: 180,
  format: "png",
});
---


<!-- Inject structured data into the page if provided. This data is formatted as JSON-LD, a method recommended by Google for structured data pass:
     https://developers.google.com/search/docs/advanced/structured-data/intro-structured-data -->
{
  structuredData && (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />
  )
}

<!-- Define the character set, description, author, and viewport settings -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
<meta name="description" content={meta} />
<meta name="author" content={author} />
<meta http-equiv="X-UA-Compatible" content="ie=edge" />

<link rel="canonical" href={canonical} />
<Fragment set:html={alternateLanguageLinks} />


<!-- Facebook Meta Tags -->
<meta property="og:type" content="website" />
<meta property="og:locale" content={ogLocale} />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={ogTitle} />
<meta property="og:description" content={ogDescription} />
<meta property="og:site_name" content={SITE.title} />
<meta property="og:image" content={socialImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/png" />


<!-- Twitter Meta Tags -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={ogTitle} />
<meta name="twitter:description" content={ogDescription} />
<meta name="twitter:image" content={socialImage} />
<meta property="twitter:url" content={canonical} />

<!-- Links to the webmanifest and sitemap -->
<link rel="manifest" href="/manifest.json" />
<link rel="sitemap" href="/sitemap-index.xml" />

<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" type="image/svg+xml" href={faviconSvg.src} />
<link rel="apple-touch-icon" href={appleTouchIcon.src} />
<link rel="shortcut icon" href={appleTouchIcon.src} />

<meta name="mobile-web-app-capable" content="yes" />
<meta name="theme-color" content="#d7b286" />

