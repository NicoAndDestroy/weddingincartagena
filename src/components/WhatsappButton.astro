---

---
<div id="whatsapp">
  <a
    href="https://wa.me/573004128389?text=%20%C2%A1Cont%C3%A1ctanos%20hoy%20y%20comienza%20a%20planificar%20la%20celebraci%C3%B3n%20de%20tus%20sue%C3%B1os!"
    aria-label="Plan your wedding in Cartagena via WhatsApp"
    target="_blank"
    rel="noopener noreferrer"
    class="toggle"
  >
    <img
      src="/icons/whatsapp.svg"
      alt=""
      aria-hidden="true"
      width="28"
      height="28"
    />
  </a>
</div>
---

<style>
  #whatsapp .toggle {
    position: fixed;
    background-color: #25d366;
    display: flex;
    align-items: center;
    justify-content: center;

    box-shadow: 0 0 20px rgba(0, 0, 0, 0.15);
    border-radius: 50%;
    border: none;

    color: #fff;
    bottom: 70px;
    right: 20px;
    z-index: 50;

    width: 60px;
    height: 60px;

    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  /* Focus visible (teclado) */
  #whatsapp .toggle:focus-visible {
    outline: 3px solid #ffffff;
    outline-offset: 4px;
  }

  /* Pulse animation */
  #whatsapp .toggle::before {
    content: "";
    position: absolute;
    z-index: -1;
    inset: -5px;
    background-color: #25d366;
    border-radius: 50%;
    animation: pulse-border 1500ms ease-out infinite;
  }

  /* Respeta usuarios con reduced motion */
  @media (prefers-reduced-motion: reduce) {
    #whatsapp .toggle::before {
      animation: none;
    }

    #whatsapp .toggle {
      transition: none;
    }
  }

  @keyframes pulse-border {
    0% {
      transform: scale(1);
      opacity: 1;
    }
    100% {
      transform: scale(1.5);
      opacity: 0;
    }
  }
</style>
