---
// Import the necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import HeroSection from "@components/sections/landing/HeroSection.astro";
import ContactSection from "../components/sections/landing/Contact.astro";
import AboutSection from "../components/sections/landing/About.astro";
import ValuesSection from "@components/sections/landing/Values.astro";
import CarouselVert from "@/components/sections/landing/CarouselVert.astro";
import FAQ from "@components/sections/FAQ.astro";
import heroImage from "@images/hero-image.avif";
import faqs from "@data/faqs.json";
import features from "@data/features.json";
import featureImage from "@images/features-image.avif";
import ReviewSection from "@/components/sections/ReviewSection.astro";
import LeadForm from "@components/sections/landing/LeadForm.astro";


// Traducción
import en from "@/content/i18n/en";
const t = en;



const avatarSrcs: Array<string> = [
  "https://images.unsplash.com/photo-1568602471122-7832951cc4c5?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1531927557220-a9e23c1e4794?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1541101767792-f9b2b1c4f127?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&&auto=format&fit=facearea&facepad=3&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1492562080023-ab3db95bfbce?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
];
---

<MainLayout
  title="Wedding Planner in Cartagena, Colombia | Destination Weddings"
  description="Luxury wedding planner in Cartagena, Colombia. We design and coordinate destination weddings and exclusive events for couples worldwide."
  t={t}>
  <HeroSection
    title={t.hero.title}
    subTitle={t.hero.subTitle}
    primaryBtn={t.hero.cta}
    primaryBtnURL="https://wa.me/573004128389?text=%20%C2%A1Cont%C3%A1ctanos%20hoy%20y%20comienza%20a%20planificar%20la%20celebraci%C3%B3n%20de%20tus%20sue%C3%B1os!"
    secondaryBtnURL="/contact"
    withReview={true}
    avatars={avatarSrcs}
    rating={t.hero.rating}
    starCount={4}
    reviews={t.hero.reviews}
    src={heroImage}
    alt={t.hero.alt}
  />

  
  <AboutSection t={t} />

  <ReviewSection/>


  <ValuesSection t={t} src={featureImage} alt={t.values?.alt || "About Section of Le Mariage with our values: Passion, Unique memories and trust."} features={features} />

<FAQ t={t} faqs={faqs} />

<CarouselVert />

<LeadForm t={t} />

  <ContactSection
    title="Let's Build Your Dream Wedding Together"
    subTitle="At Le Mariage, we don't just create events, we create experiences that last a lifetime. Trust us to make your most cherished dreams come true and transform every moment into a memory you'll cherish forever."
    url="https://wa.me/573004128389?text=%20%C2%A1Cont%C3%A1ctanos%20hoy%20y%20comienza%20a%20planificar%20la%20celebraci%C3%B3n%20de%20tus%20sue%C3%B1os!"
    alt="FAQ Section of Le Mariage with the most coomon queries and answers."  
    />
</MainLayout>